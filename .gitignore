# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv


# ── User data — NEVER commit these ────────────────────────────────────────────
# Face encodings and config contain personal data and secrets.
# The ~/.faceguard/ directory path itself won't appear in a repo clone,
# but these patterns catch any relative path accidents.
*.pkl
config.json
roster.pkl

# Capture photos and enrolled reference photos
photos/
*.jpg
*.jpeg
*.png
*.aiff
*.mp3
*.wav

# Runtime files
*.pid
faceguard.pid
launchagent.out
launchagent.err
lmstudio.out
lmstudio.err

# Compiled plist (generated by make install — not the template)
*.plist
!scripts/*.plist.template

